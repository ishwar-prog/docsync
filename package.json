{
  "name": "@ishwarrr/docsync",
  "version": "0.1.0",
  "description": "Auto-updating documentation that stays true to your code. Detects drift between code and docs, generates AI documentation, and opens companion PRs automatically.",
  "main": "src/index.js",
  "bin": {
    "docsync": "bin/docsync.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    "src/",
    "action.yml",
    "README.md",
    "LICENSE"
  ],
 "scripts": {
  "start": "node src/index.js",
  "dev": "nodemon src/index.js",
  "cli": "node bin/docsync.js",
  "test": "jest --passWithNoTests",
  "lint": "eslint src/",
  "lint:fix": "eslint src/ --fix",
  "build:action": "ncc build src/action/index.js -o dist --license licenses.txt",
  "prepublishOnly": "npm run build:action && npm run lint && npm test",
  "prepack": "npm run build:action && node scripts/validate-publish.js"
},

  "keywords": [
    "documentation",
    "developer-tools",
    "ast",
    "github-app",
    "cli",
    "drift-detection",
    "ai",
    "tree-sitter",
    "github-actions",
    "docs-as-code"
  ],
  "author": "Ishwar Suthar <ishwar16suthar@gmail.com>",
  "license": "MIT",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ishwar-prog/docsync.git"
  },
  "bugs": {
    "url": "https://github.com/ishwar-prog/docsync/issues"
  },
  "homepage": "https://github.com/ishwar-prog/docsync#readme",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0",
    "@octokit/app": "^4.0.0",
    "@octokit/rest": "^19.0.13",
    "@octokit/webhooks": "^10.9.2",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10",
    "groq-sdk": "^0.3.3",
    "js-yaml": "^4.1.0",
    "ora": "^5.4.1",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.21.4",
    "tree-sitter-typescript": "^0.21.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^9.14.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7"
  }
}
